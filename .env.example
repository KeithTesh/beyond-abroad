# FILE: .env.example
# Copy this file to .env.local and fill in every value
# NEVER commit .env.local to GitHub — it is in .gitignore
#
# WHERE TO GET EACH VALUE:
#   RESEND_API_KEY       → resend.com → API Keys → Create key
#   RESEND_AUDIENCE_ID   → resend.com → Audiences → "Beyond Abroad Subscribers" → copy ID
#   RESEND_FROM_EMAIL    → a verified domain in Resend  (use onboarding@resend.dev for local testing)
#   SANITY_PROJECT_ID    → sanity.io → project → Settings → API → Project ID
#   SANITY_API_TOKEN     → sanity.io → project → Settings → API → Tokens → Add Editor token

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@beyondabroad.com
CONTACT_TO_EMAIL=carolmwenda09@gmail.com

# Sanity  (sanity init fills these automatically)
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxxx
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=skxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# i18n
NEXT_PUBLIC_DEFAULT_LOCALE=en